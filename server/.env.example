# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL:  postgresql://user:password@localhost:5432/whatsapp_manager
# Neon (serverless): postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_manager

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX

# ─── WhatsApp Webhook ──────────────────────────────────────────────────────────
# Choose any secret string — enter the same value in Meta Developer Console
WEBHOOK_VERIFY_TOKEN=your_secret_webhook_token

# Get from Meta Developer Console → App Settings → Basic → App Secret
# Leave empty to skip signature verification (not recommended in production)
META_APP_SECRET=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Your VPS domain or IP (e.g. http://1.2.3.4:3001 or https://yourdomain.com)
# In production the Express server serves the frontend, so this can match the server URL
CLIENT_URL=http://YOUR_VPS_IP:3001

# ─── WhatsApp API ──────────────────────────────────────────────────────────────
WHATSAPP_API_VERSION=v18.0
